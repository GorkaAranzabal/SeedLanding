# Copy to .env.local and fill in. .env.local is gitignored by Next.js.

# kie.ai — Nano Banana 2 image generation (style preview)
KIE_API_KEY=

# OpenRouter — the vibecoding agent that writes the Three.js game
OPENROUTER_API_KEY=
# Optional. Defaults to minimax/minimax-m2.7
# OPENROUTER_MODEL=minimax/minimax-m2.7
# Optional attribution headers shown on OpenRouter
# OPENROUTER_SITE_URL=https://seed.games
# OPENROUTER_SITE_NAME=Seed
